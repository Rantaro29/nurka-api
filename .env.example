# Nurka API Environment Configuration Example
# Copy this file to .env and fill in your actual values

# API Authentication Token
# Generate a secure token for API authentication
API_AUTH_TOKEN=your_secure_api_token_here

# Database Configuration
# Format: postgresql+asyncpg://username:password@host:port/database_name
DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/nurka_db

# Optional: Debug mode (set to true for development)
# DEBUG=false